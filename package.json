{
  "name": "goth-frontend",
  "description": "GOTH Stack - Minimalist Frontend (HTMX + Tailwind)",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./web/static/assets/css/tailwind.css -o ./web/static/assets/styles.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./web/static/assets/css/tailwind.css -o ./web/static/assets/styles.css --watch"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.1"
  }
}

# API and web handlers - security sensitive
/internal/web/** @PauloHFS
/internal/middleware/** @PauloHFS
/internal/web/broker.go @PauloHFS

# Authentication and authorization
/internal/auth/** @PauloHFS
/internal/session/** @PauloHFS


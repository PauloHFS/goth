# ===========================================
# GOTH Stack - Environment Secrets
# ===========================================
# Copie este arquivo para .env e preencha os segredos:
#   cp .env.example .env
#
# ⚠️ IMPORTANTE: Este arquivo contém APENAS SEGREDOS.
# Toda configuração estrutural (ports, URLs, timeouts, etc)
# está no config.yaml, organizada por ambiente.
#
# Documentação completa: README.md

# -------------------------------------------
# Application
# -------------------------------------------
# Ambiente: dev, staging, prod
APP_ENV=dev

# Domínio (obrigatório para SSL automático em produção)
# Exemplos:
#   - meuapp.com
#   - app.minhaempresa.com.br
APP_DOMAIN=

# -------------------------------------------
# Session & Security
# -------------------------------------------
# Produção: OBRIGATÓRIO - gere um secret seguro:
#   openssl rand -hex 32
# Desenvolvimento: pode deixar vazio (gerado automaticamente)
SESSION_SECRET=

# Produção: OBRIGATÓRIO - pepper para password hashing:
#   openssl rand -hex 16
# Desenvolvimento: pode deixar vazio (gerado automaticamente)
PASSWORD_PEPPER=

# -------------------------------------------
# SMTP (E-mails Transacionais)
# -------------------------------------------
# Desenvolvimento: Use Mailhog (já incluso no docker-compose)
#   SMTP_HOST=mailhog
#   SMTP_PORT=1025
#   SMTP_USER= (vazio)
#   SMTP_PASS= (vazio)
#
# Produção: Configure seu provedor SMTP (SendGrid, AWS SES, etc)
SMTP_USER=
SMTP_PASS=

# -------------------------------------------
# OAuth2 (Login Social)
# -------------------------------------------
# Configure no Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# Asaas (Gateway de Pagamento Brasileiro)
# ------------------------------------------
# Sandbox: https://sandbox.asaas.com/
# Production: https://www.asaas.com/
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=
ASAAS_HMAC_SECRET=

# -------------------------------------------
# Traefik (Proxy Reverso & SSL)
# -------------------------------------------
# HTTP port (default: 80)
TRAEFIK_HTTP_PORT=80

# HTTPS port (default: 443)
TRAEFIK_HTTPS_PORT=443

# Dashboard (development only!)
# Host para acessar o dashboard (default: traefik.localhost)
TRAEFIK_DASHBOARD_HOST=traefik.localhost
# Porta do dashboard (default: 8080)
TRAEFIK_DASHBOARD_PORT=8080
# Autenticação (formato: user:password)
# Gere com: echo $(htpasswd -nb admin admin) | sed -e 's/:/\\:/g'
TRAEFIK_DASHBOARD_AUTH=admin:admin

# -------------------------------------------
# Telemetry Stack (OpenTelemetry + Grafana)
# -------------------------------------------
# Versões
OTEL_VERSION=0.100.0
GRAFANA_VERSION=11.0.0
LOKI_VERSION=3.0.0
TEMPO_VERSION=2.4.0
PROMETHEUS_VERSION=v2.52.0

# OTel Collector Endpoint (gRPC)
# Use otelcol:4317 for container networking
OTEL_EXPORTER_OTLP_ENDPOINT=otelcol:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# OTel Service Name
OTEL_SERVICE_NAME=goth

# -------------------------------------------
# Grafana (Visualização)
# -------------------------------------------
# Porta (default: 3001 para evitar conflito com Traefik dashboard)
GRAFANA_PORT=3001

# Autenticação (PRODUÇÃO: SEMPRE ATIVAR!)
GRAFANA_AUTH_ANONYMOUS=false
GRAFANA_AUTH_DISABLE_LOGIN=false
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# -------------------------------------------
# Backup (Litestream + S3 Compatible)
# -------------------------------------------
# Ativar backup? (use: --profile prod ao subir)
# REPLICA_URL=  # Deixe vazio para desenvolvimento!

# URL de replicação (S3, Backblaze B2, MinIO, etc)
# Formatos:
#   - s3://bucket-name/goth.db (AWS S3)
#   - s3://bucket-name/goth.db + AWS_REGION=auto (Backblaze B2)
#   - s3://localhost:9000/bucket/goth.db (MinIO local)
REPLICA_URL=

# Retenção (default: 7 dias = 168h)
REPLICA_RETENTION=168h

# S3 Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


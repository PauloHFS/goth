# Application
APP_NAME=goth
ENV=dev
PORT=8080

# Database
DATABASE_URL=/tmp/goth.db
MAX_OPEN_CONNS=25
MAX_IDLE_CONNS=5
CONN_MAX_LIFETIME=300

# Session
SESSION_KEY=change-me-in-production-min-32-chars

# OAuth - Google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# OAuth - GitHub (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback

# Password Pepper (min 32 chars)
PASSWORD_PEPPER=change-me-in-production-min-32-chars

# Worker
WORKER_COUNT=3

# Asaas (Billing)
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=
ASAAS_HMAC_SECRET=

# Litestream (Backup)
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_BUCKET=
LITESTREAM_REGION=

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENV=dev

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3001

# Feature Flags
FEATURE_NEW_DASHBOARD=true
FEATURE_BETA=true
